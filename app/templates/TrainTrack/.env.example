# TrainTrack Environment Configuration
# Copy this file to .env and fill in your values.

# Database
DB_HOST=traintrack-db
DB_USER=traintrack
DB_PASSWORD=change-me
DB_NAME=traintrack
DB_ROOT_PASSWORD=change-me-root

# Application
TRAINTRACK_ROLE=client
SECRET_KEY=change-me-secret-key
PYTHONUNBUFFERED=1

# Optional
# TRAINTRACK_SYNC_USER=
# TRAINTRACK_EDITION=personal
